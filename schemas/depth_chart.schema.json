{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DepthChart",
  "description": "Roster for one position group. Drives next-man-up continuity.",
  "type": "object",
  "required": ["position_group", "roster"],
  "properties": {
    "position_group": { "type": "string" },
    "criticality_tier": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
    "human_coach": { "type": "string" },
    "human_failover_owner": { "type": "string" },
    "conditioning_max_age_days": { "type": "integer", "minimum": 0 },
    "roster": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["agent_id", "depth_chart"],
        "properties": {
          "agent_id": { "type": "string" },
          "depth_chart": {
            "type": "string",
            "enum": ["starter", "backup", "second_string", "specialist", "rotational"]
          },
          "eligible": { "type": "boolean" },
          "last_conditioning": { "type": "string" },
          "strengths": { "type": "array", "items": { "type": "string" } },
          "permissions": {
            "type": "object",
            "properties": {
              "may": { "type": "array", "items": { "type": "string" } },
              "may_not_without_human_approval": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    }
  }
}
