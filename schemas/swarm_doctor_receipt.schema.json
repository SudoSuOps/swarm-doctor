{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SwarmDoctorReceipt",
  "description": "Triage chart emitted by cli/swarm_doctor.py. The baton handed to eval-curator.",
  "type": "object",
  "required": [
    "schema_version",
    "agent_id",
    "agent_name",
    "host",
    "symptom",
    "vitals_status",
    "pulse_status",
    "bloodwork_findings",
    "neuro_findings",
    "recent_changes",
    "findings",
    "root_cause_category",
    "diagnosis",
    "diagnosis_confidence",
    "treatment_plan",
    "time_to_recovery_minutes",
    "human_required",
    "discharge_status",
    "ready_for_eval_curator",
    "offline_mode",
    "timestamp",
    "receipt_sha256"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "offline_mode": { "type": "boolean", "description": "true = source data never leaves the office" },
    "offline_note": { "type": "string" },
    "agent_id": { "type": "string", "description": "plain id or ENS, e.g. agent01.client.defendable.eth" },
    "agent_ens": {
      "type": ["string", "null"],
      "description": "ENS name if used, e.g. agent01.client.defendable.eth",
      "pattern": "^[a-z0-9][a-z0-9-]*(\\.[a-z0-9][a-z0-9-]*)+\\.eth$"
    },
    "agent_name": { "type": "string" },
    "host": { "type": "string" },
    "symptom": { "type": "string" },
    "vitals_status": {
      "type": "string",
      "enum": ["alive", "dead", "crash_loop", "hung", "unreachable"]
    },
    "vitals_probe": {
      "type": ["object", "null"],
      "description": "Result of the one real vitals probe, if --probe was used. Null otherwise.",
      "properties": {
        "vitals_state": { "type": "string" },
        "process_up": { "type": "boolean" },
        "crash_count": { "type": "integer" },
        "source": { "type": "string", "enum": ["systemctl", "docker"] },
        "command": { "type": "string" },
        "raw": { "type": "string" }
      }
    },
    "pulse_status": { "type": "string", "enum": ["ok", "degraded", "flatline"] },
    "bloodwork_findings": { "type": "array", "items": { "type": "string" } },
    "neuro_findings": { "type": "array", "items": { "type": "string" } },
    "recent_changes": { "type": "array", "items": { "type": "string" } },
    "last_known_good": {
      "type": ["object", "null"],
      "description": "Reference state the operator considers healthy; the recovery target."
    },
    "metrics": {
      "type": "object",
      "description": "Computed health math. Informational; thresholds drive the decision.",
      "properties": {
        "heartbeat_success_rate": { "type": "number" },
        "error_rate": { "type": "number" },
        "successful_probe_count": { "type": "integer" },
        "consecutive_failures": { "type": "integer" },
        "latency_ms": { "type": "number" },
        "gpu_memory_used_pct": { "type": "number" },
        "context_tokens_pct": { "type": "number" },
        "stability_score": { "type": "number" }
      }
    },
    "findings": {
      "type": "array",
      "description": "Explicit HARD_FAULT / SOFT_WARNING taxonomy with root cause per finding.",
      "items": {
        "type": "object",
        "required": ["severity", "category", "message"],
        "properties": {
          "severity": { "type": "string", "enum": ["HARD_FAULT", "SOFT_WARNING"] },
          "category": {
            "type": "string",
            "enum": ["infra", "model", "retrieval", "tool_call", "prompt", "context", "network", "auth", "unknown"]
          },
          "message": { "type": "string" }
        }
      }
    },
    "hard_faults": { "type": "array", "items": { "type": "string" } },
    "soft_warnings": { "type": "array", "items": { "type": "string" } },
    "root_cause_category": {
      "type": "string",
      "enum": ["infra", "model", "retrieval", "tool_call", "prompt", "context", "network", "auth", "unknown", "none"]
    },
    "diagnosis": { "type": "string" },
    "diagnosis_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "treatment_plan": { "type": "array", "items": { "type": "string" } },
    "time_to_recovery_minutes": { "type": "number", "description": "Operator estimate, not a promise." },
    "human_required": { "type": "boolean" },
    "discharge_status": {
      "type": "string",
      "enum": ["TREATMENT_REQUIRED", "OBSERVE", "DISCHARGE_TO_EVAL_CURATOR"]
    },
    "ready_for_eval_curator": { "type": "boolean" },
    "continuity_action": {
      "type": ["object", "null"],
      "description": "Next-man-up roster action. Null unless a depth chart was supplied.",
      "properties": {
        "triggered": { "type": "boolean" },
        "trigger_reason": { "type": ["string", "null"] },
        "position_group": { "type": "string" },
        "criticality_tier": { "type": "string", "enum": ["critical", "material", "low_risk"] },
        "environment": { "type": "string" },
        "starter": { "type": "string" },
        "starter_status": { "type": "string", "enum": ["ACTIVE", "OBSERVE", "INJURED_RESERVE"] },
        "outcome": {
          "type": "string",
          "description": "A continuity event resolves to exactly one of the three locked outcomes.",
          "enum": [
            "NO_CONTINUITY_EVENT",
            "MONITOR",
            "BACKUP_RESTRICTED_DUTY",
            "HUMAN_FAILOVER_SAFE_MODE",
            "OPERATIONS_SUSPENDED"
          ]
        },
        "workflow_status": {
          "type": "string",
          "enum": ["NORMAL", "DEGRADED_MONITORED", "COVERED_BY_BACKUP", "COVERED_BY_HUMAN_SAFE_MODE", "SUSPENDED"]
        },
        "activated": { "type": ["string", "null"] },
        "activated_permissions": {
          "type": "array", "items": { "type": "string" },
          "description": "Only the activated backup's APPROVED reduced play set — never starter authority."
        },
        "requires_human_approval": { "type": "array", "items": { "type": "string" } },
        "receipts_preserved": { "type": "boolean" },
        "human_owner": { "type": ["string", "null"] },
        "human_owner_notified": { "type": "boolean" },
        "escalation_urgency": {
          "type": "string",
          "enum": ["none", "log_and_queue_owner_notice", "urgent_notification", "immediate_page"]
        },
        "limitations": { "type": "array", "items": { "type": "string" } }
      }
    },
    "timestamp": { "type": "string", "format": "date-time" },
    "receipt_sha256": { "type": "string", "description": "sha256 over the receipt minus this field." }
  }
}
